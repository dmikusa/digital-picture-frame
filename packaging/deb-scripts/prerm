set -e

case "$1" in
  remove|upgrade|deconfigure)
    # Stop services before removal
    systemctl stop photo-frame-display.service || true
    systemctl stop photo-frame-manager.service || true
    ;;

  failed-upgrade)
    ;;

  *)
    echo "prerm called with unknown argument \`$1'" >&2
    exit 1
    ;;
esac

exit 0
